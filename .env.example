# ============================================================
# natsx 环境变量模板
# 复制为 .env 后填入实际值（.env 已在 .gitignore 中排除）
#
# NATS L2 adapter — 连接完全由环境变量注入
# 规范前缀 FOUNDATIONX_NATS_* 优先于旧版 NATS_*
# ============================================================

# ---- 连接 ----
# NATS Server URL（单节点；多节点用 FOUNDATIONX_NATS_SERVERS）
FOUNDATIONX_NATS_URL=nats://localhost:4222
# 多节点列表（逗号分隔，优先于 URL）
# FOUNDATIONX_NATS_SERVERS=nats://host1:4222,nats://host2:4222

# ---- 认证（敏感，不设默认值）----
# FOUNDATIONX_NATS_USERNAME=
# FOUNDATIONX_NATS_PASSWORD=
# FOUNDATIONX_NATS_TOKEN=
# FOUNDATIONX_NATS_NKEY_SEED=
# FOUNDATIONX_NATS_CREDENTIALS_FILE=

# ---- 客户端标识 ----
# FOUNDATIONX_NATS_NAME=
# FOUNDATIONX_NATS_CLIENT_NAME=

# ---- 超时与重连 ----
# FOUNDATIONX_NATS_TIMEOUT=5s
# FOUNDATIONX_NATS_DRAIN_TIMEOUT=10s
# FOUNDATIONX_NATS_MAX_RECONNECTS=10
# FOUNDATIONX_NATS_RECONNECT_WAIT=2s

# ---- JetStream ----
# 设为 true 启用 JetStream 上下文
# FOUNDATIONX_NATS_ENABLE_JETSTREAM=false

# ---- 集成测试 ----
# 设为 1 启用真实 NATS dev auth live gate 验证
NATSX_LIVE_INTEGRATION=0
# 示例程序使用的 URL（简化版，非规范前缀）
NATS_URL=nats://localhost:4222
