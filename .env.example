# ============================================================
# natsx 环境变量模板
# 复制为 .env 后填入实际值
# .env 文件已在 .gitignore 中排除，禁止提交
#
# 密钥命名约定：前缀 FOUNDATIONX_NATSX_
# ============================================================

# ---- 实例标识 ----
FOUNDATIONX_NATSX_NAME=natsx

# ---- NATS 服务器 ----
# 单节点 URL 或逗号分隔的多节点列表
FOUNDATIONX_NATSX_URL=nats://127.0.0.1:4222
# 备选：FOUNDATIONX_NATSX_SERVERS=nats://host1:4222,nats://host2:4222

# ---- 认证 ----
FOUNDATIONX_NATSX_TOKEN=
FOUNDATIONX_NATSX_USERNAME=
FOUNDATIONX_NATSX_PASSWORD=
FOUNDATIONX_NATSX_NKEY_SEED=
FOUNDATIONX_NATSX_CREDENTIALS_FILE=

# ---- 超时 ----
FOUNDATIONX_NATSX_TIMEOUT=5s
FOUNDATIONX_NATSX_DRAIN_TIMEOUT=30s
FOUNDATIONX_NATSX_RECONNECT_WAIT=1s

# ---- 重连 ----
FOUNDATIONX_NATSX_MAX_RECONNECTS=-1

# ---- JetStream ----
FOUNDATIONX_NATSX_ENABLE_JETSTREAM=false
